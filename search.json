---
layout: null
---
{% assign searchable = "" | split: "" %}
{% for p in site.pages %}
  {% unless p.url contains '/assets/' or p.url contains '/feed' or p.url == '/search.json' %}
    {% assign searchable = searchable | push: p %}
  {% endunless %}
{% endfor %}
{% for p in site.posts %}
  {% assign searchable = searchable | push: p %}
{% endfor %}
[{% for p in searchable %}{% assign body = p.content | strip_html | strip_newlines | normalize_whitespace %}{"title":{{ p.title | default: p.url | append: '' | jsonify }},"url":{{ p.url | relative_url | jsonify }},"excerpt":{{ p.excerpt | default: body | strip_html | strip_newlines | truncate: 120 | jsonify }},"body":{{ body | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
